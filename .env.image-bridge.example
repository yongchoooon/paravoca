# Required: OpenAI API key used only by the bridge server.
IMAGE_BRIDGE_OPENAI_API_KEY=sk-...

# Strongly recommended: Ennoia API connector must send Authorization: Bearer <token>.
IMAGE_BRIDGE_TOKEN=change-me-long-random-secret

# Optional defaults.
IMAGE_BRIDGE_MODEL=gpt-image-2
IMAGE_BRIDGE_DEFAULT_SIZE=1024x1536
IMAGE_BRIDGE_DEFAULT_QUALITY=low
IMAGE_BRIDGE_STORAGE_DIR=data/images

# Set this to your Cloudflare Tunnel public URL after publishing the service.
# Example: https://image-api.example.com
IMAGE_BRIDGE_PUBLIC_BASE_URL=
